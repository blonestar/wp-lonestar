{
  "name": "lonestar-theme",
  "version": "0.5.0",
  "private": true,
  "description": "Lonestar Framework parent theme tooling",
  "author": "Bojan Ab",
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/blonestar/wp-lonestar.git"
  },
  "homepage": "https://github.com/blonestar/wp-lonestar",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "browsers": "browserslist",
    "format": "prettier --write \"**/*.{js,jsx,json,css,scss,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,json,css,scss,md,yml,yaml}\"",
    "test": "node --test tests/*.test.mjs",
    "validate:json": "node scripts/validate-json.mjs",
    "package:check": "node scripts/validate-package.mjs",
    "i18n:pot": "wp i18n make-pot . languages/lonestar.pot --domain=lonestar --exclude=node_modules,vendor,.git,dist,build,coverage,tests --headers='{\"POT-Creation-Date\":\"\"}'",
    "audit": "npm audit --audit-level=high",
    "check": "npm run validate:json && npm run format:check && npm test && npm run build && npm run package:check"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "browserslist": [
    "extends @wordpress/browserslist-config"
  ],
  "devDependencies": {
    "@wordpress/browserslist-config": "^6.51.0",
    "autoprefixer": "^10.5.4",
    "browserslist": "^4.28.5",
    "postcss": "^8.5.19",
    "postcss-nesting": "^14.0.0",
    "prettier": "^3.9.5",
    "vite": "^8.1.5"
  }
}
